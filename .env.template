# Camunda Platform 8 SaaS Configuration
# Copy this file to .env and fill in your credentials from https://camunda.io/

# Zeebe Configuration for Java Booking Service
ZEEBE_CLIENT_CLOUD_REGION=cdg-1
ZEEBE_CLIENT_CLOUD_CLUSTERID=your-cluster-id
ZEEBE_CLIENT_CLOUD_CLIENTID=your-client-id
ZEEBE_CLIENT_CLOUD_CLIENTSECRET=your-client-secret

# Zeebe Configuration for Node.js Fake Services
# Format: cluster-id.region.zeebe.camunda.io:443
ZEEBE_ADDRESS=your-cluster-id.cdg-1.zeebe.camunda.io:443
ZEEBE_CLIENT_ID=your-client-id
ZEEBE_CLIENT_SECRET=your-client-secret
ZEEBE_AUTHORIZATION_SERVER_URL=https://login.cloud.camunda.io/oauth/token
ZEEBE_TOKEN_AUDIENCE=zeebe.camunda.io
