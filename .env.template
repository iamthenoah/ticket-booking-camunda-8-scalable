# Copy this file to .env and fill in your values.

# Camunda Platform 8 SaaS values (used by both apps)
CAMUNDA_CLUSTER_REGION=cdg-1
CAMUNDA_CLUSTER_ID=your-cluster-id
CAMUNDA_CLIENT_ID=your-client-id
CAMUNDA_CLIENT_SECRET=your-client-secret
CAMUNDA_OAUTH_URL=https://login.cloud.camunda.io/oauth/token

# Zeebe worker values for the Node.js service
# Format: cluster-id.region.zeebe.camunda.io:443
ZEEBE_ADDRESS=your-cluster-id.cdg-1.zeebe.camunda.io:443
ZEEBE_CLIENT_ID=your-client-id
ZEEBE_CLIENT_SECRET=your-client-secret
ZEEBE_AUTHORIZATION_SERVER_URL=https://login.cloud.camunda.io/oauth/token
ZEEBE_TOKEN_AUDIENCE=zeebe.camunda.io
CAMUNDA_TOKEN_AUDIENCE=zeebe.camunda.io

# Local Docker defaults
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ticketbooking
SPRING_DATASOURCE_USERNAME=ticketbooking
SPRING_DATASOURCE_PASSWORD=ticketbooking
