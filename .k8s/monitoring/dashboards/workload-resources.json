        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "max by (deployment) (kube_deployment_status_replicas{namespace=\"$namespace\", deployment=~\"${workload:regex}\"})",
          "legendFormat": "{{deployment}}",
          "refId": "A"
        }
      ],
      "title": "Current Replica Count",
      "type": "timeseries"
