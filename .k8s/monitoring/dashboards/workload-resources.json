      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"(${workload:regex})-.*\", container!=\"POD\", image!=\"\"}[$__rate_interval]))",
